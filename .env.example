# KAC-127 Phase 2 — Auth-flow env (configurable domain).
#
# Vite expose-ит только переменные с префиксом `VITE_` в SPA-bundle.
# Все значения ниже — defaults; в prod подменяет environment kacho-deploy.
#
# === Core API ===
# api-gateway REST endpoint (same-origin в prod через ingress; localhost в dev).
VITE_KACHO_API_BASE=
# Apex домен для production (используется как fallback origin/host для UI).
VITE_KACHO_API_DOMAIN=api.kacho.cloud
# Origin приложения (для WebAuthn rpId / Hydra audience). В prod — `app.kacho.cloud`.
VITE_APP_DOMAIN=app.kacho.cloud

# === Ory Kratos (self-service auth flows: login / registration / settings / recovery / logout) ===
# Public base URL для browser-flows. В prod — same-origin path-prefix `/.ory/kratos/public`.
# В dev — direct upstream `http://localhost:4433` (см. vite.config.ts proxy).
VITE_KRATOS_URL=/.ory/kratos/public

# === Ory Hydra (OAuth2 / OIDC issuer для access-token + BCL session sync) ===
VITE_HYDRA_URL=/oauth2
# Hydra OAuth2 client_id для kacho-ui SPA-flow (Public client, PKCE).
VITE_HYDRA_CLIENT_ID=kacho-ui
# Redirect URI после OAuth-callback. Default — same-origin `/auth/callback`.
VITE_HYDRA_REDIRECT_URI=/auth/callback
# Scopes для SPA-токена (openid + offline_access для refresh).
VITE_HYDRA_SCOPES=openid profile email offline_access

# === WebAuthn / Passkey ===
# RP-ID для WebAuthn (eTLD+1 от VITE_APP_DOMAIN). Kratos config обязан совпадать.
VITE_WEBAUTHN_RP_ID=kacho.cloud
VITE_WEBAUTHN_RP_NAME=Kachō Cloud

# === DPoP ===
# Время свежести MFA для step-up (минуты). После — UI триггерит StepUpModal.
VITE_MFA_FRESH_TTL_MIN=15
# Allowed clock-skew DPoP nonce (секунды).
VITE_DPOP_CLOCK_SKEW_SEC=30

# === Step-up / Recovery ===
# Recovery magic-link TTL (минуты) — UI показывает в success-сообщении.
VITE_RECOVERY_LINK_TTL_MIN=5

# === Dev-only ===
# api-gateway base для vite dev-proxy (server-side env, не expose-ится).
KACHO_API_BASE=http://localhost:8080
KACHO_KRATOS_BASE=http://localhost:4433
KACHO_HYDRA_BASE=http://localhost:4444
